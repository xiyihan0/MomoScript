# Git internals (avoid committing nested repos)
.git/

# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class
*.egg-info/

# Virtual environments
.venv/
venv/
ENV/

# Test / type-check / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# IDEs
.idea/
.vscode/

# OS junk
.DS_Store
Thumbs.db

# Local env / secrets
.env
.env.*

# Project caches / temp outputs
.cache/
.tmp/
*.log

# Large downloaded assets (regenerate via scripts)
# images/
typst_sandbox/mmt_render/images/

# If you want to version only tags metadata (but not images), replace the line above
# with the following block:
# typst_sandbox/mmt_render/images/**
images/**
!images/students/
!images/students/**/
!images/students/**/tags.json

# Avatar images are large; keep mapping JSONs
avatar/*
!avatar/name_to_id.json
!avatar/download_errors.json

# Packs: ignore large assets, keep metadata/json
typst_sandbox/mmt_packs/**
!typst_sandbox/mmt_packs/
!typst_sandbox/mmt_packs/**/
!typst_sandbox/mmt_packs/README.md
!typst_sandbox/mmt_packs/**/manifest.json
!typst_sandbox/mmt_packs/**/char_id.json
!typst_sandbox/mmt_packs/**/asset_mapping.json
!typst_sandbox/mmt_packs/**/images/**/tags.json
**.png
!screenshots/final-monaco-real-avatar.png
!editors/vscode-web/e2e/fixtures/佳代子.png
!editors/vscode-web/public/intro-assets/
!editors/vscode-web/public/intro-assets/*.png
**.jpg

# Browser test artifacts
editors/vscode-web/test-results/

# Pack v2 workspace:
# - Only keep the base pack `typst_sandbox/pack-v2/ba/` in git.
# - Other packs (e.g. third-party extension packs) stay local-only for now.
typst_sandbox/pack-v2/*
!typst_sandbox/pack-v2/ba/

# For `typst_sandbox/pack-v2/ba/`, keep metadata + tags, ignore large assets by default.
typst_sandbox/pack-v2/ba/**
!typst_sandbox/pack-v2/ba/images/
!typst_sandbox/pack-v2/ba/images/**/
!typst_sandbox/pack-v2/ba/manifest.json
!typst_sandbox/pack-v2/ba/char_id.json
!typst_sandbox/pack-v2/ba/asset_mapping.json
!typst_sandbox/pack-v2/ba/images/**/tags.json

# Pack v3 workspace: keep manifest + build reports + raw sources, ignore large binary assets
# (blobs/assets are rebuilt locally and distributed via OSS/CDN, not git).
typst_sandbox/pack-v3/**
!typst_sandbox/pack-v3/
!typst_sandbox/pack-v3/**/
!typst_sandbox/pack-v3/**/manifest.json
!typst_sandbox/pack-v3/**/build_report.json
!typst_sandbox/pack-v3/**/encode_report.jsonl
!typst_sandbox/pack-v3/**/sources/**

# Copy under typst_sandbox/mmt_render is cache only
typst_sandbox/mmt_render/avatar/

# Typst / exports
*.pdf
*.webp
!typst_sandbox/mmt_render/mmt_options.webp
!typst_sandbox/mmt_render/mmt_favor.webp

# mmt_render generated artifacts
typst_sandbox/mmt_render/*.pipe.json
typst_sandbox/mmt_render/*.pipe.resolved.json
typst_sandbox/mmt_render/*.pipe.pdf
typst_sandbox/mmt_render/*.resolved.json
typst_sandbox/mmt_render/*.report.json
typst_sandbox/mmt_render/*.render*.json

# MomoScript Test Examples
typst_sandbox/mmt_render/*.txt

# Backup files
*.bak/

# Demo/Test tool files
tools/*demo.py 

# Profile reports
result.json

examples/

mmt_rs/target/
mmt_lsp/target/
web/.vite/
editors/vscode-web/node_modules/
editors/vscode-web/dist/
editors/vscode-web/.vite/

# Local Netlify folder
.netlify
