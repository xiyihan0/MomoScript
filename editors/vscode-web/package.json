{
  "name": "momoscript-vscode-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "predev": "node ../vscode/scripts/verify-web-vendor.mjs",
    "dev": "vite",
    "precheck": "node ../vscode/scripts/verify-web-vendor.mjs",
    "check": "tsc --noEmit",
    "build": "node ../vscode/scripts/verify-web-vendor.mjs && node --max-old-space-size=8192 ./node_modules/vite/bin/vite.js build",
    "preview": "vite preview",
    "test:e2e": "playwright test --project=local",
    "test:e2e:chrome": "playwright test --project=chrome",
    "test:avifs-worker": "npm run build && node ./scripts/test-avifs-worker.mjs",
    "test:resource-cache": "node --experimental-strip-types ./scripts/test-bounded-string-cache.mjs",
    "test:resource-fetch-cache": "node --experimental-strip-types ./scripts/test-resource-fetch-cache.mjs",
    "test:resource-materializer": "node --experimental-strip-types ./scripts/test-resource-materializer.mjs",
    "test:resource-settings": "node --experimental-strip-types ./scripts/test-resource-settings.mjs",
    "test:language-projection": "node --experimental-strip-types ./scripts/test-language-projection.mjs",
    "test:runtime-owner": "node --experimental-strip-types ./scripts/test-runtime-owner.mjs",
    "test:e2e:remote": "playwright test --project=remote"
  },
  "dependencies": {
    "@codingame/monaco-vscode-api": "21.6.0",
    "@codingame/monaco-vscode-editor-api": "21.6.0",
    "@codingame/monaco-vscode-editor-service-override": "21.6.0",
    "@codingame/monaco-vscode-explorer-service-override": "21.6.0",
    "@codingame/monaco-vscode-files-service-override": "21.6.0",
    "@codingame/monaco-vscode-keybindings-service-override": "21.6.0",
    "@codingame/monaco-vscode-language-pack-zh-hans": "^21.6.0",
    "@codingame/monaco-vscode-localization-service-override": "^21.6.0",
    "@codingame/monaco-vscode-markers-service-override": "21.6.0",
    "@codingame/monaco-vscode-output-service-override": "^21.6.0",
    "@codingame/monaco-vscode-preferences-service-override": "^21.6.0",
    "@codingame/monaco-vscode-textmate-service-override": "21.6.0",
    "@codingame/monaco-vscode-theme-defaults-default-extension": "21.6.0",
    "@codingame/monaco-vscode-theme-service-override": "21.6.0",
    "@codingame/monaco-vscode-theme-seti-default-extension": "21.6.0",
    "@codingame/monaco-vscode-view-status-bar-service-override": "21.6.0",
    "@codingame/monaco-vscode-views-service-override": "21.6.0",
    "@myriaddreamin/typst-ts-renderer": "0.7.0-rc2",
    "@myriaddreamin/typst-ts-web-compiler": "0.7.0-rc2",
    "@myriaddreamin/typst.ts": "0.7.0-rc2",
    "monaco-editor": "npm:@codingame/monaco-vscode-editor-api@21.6.0",
    "monaco-languageclient": "10.0.0",
    "vscode": "npm:@codingame/monaco-vscode-extension-api@21.6.0",
    "vscode-languageclient": "9.0.1",
    "vscode-languageserver": "9.0.1"
  },
  "devDependencies": {
    "@codingame/esbuild-import-meta-url-plugin": "1.0.3",
    "@playwright/test": "1.55.0",
    "@types/node": "22.12.0",
    "typescript": "5.9.3",
    "vite": "7.3.1"
  }
}
