{
  "name": "momoscript-vscode",
  "displayName": "MomoScript",
  "description": "为 MomoScript 视觉叙事 DSL 提供语言支持。",
  "version": "0.1.0",
  "publisher": "momoscript",
  "license": "MPL-2.0",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:mmt"
  ],
  "main": "./dist/extension.js",
  "browser": "./dist/extension.web.js",
  "contributes": {
    "languages": [
      {
        "id": "mmt",
        "aliases": [
          "MomoScript",
          "mmt"
        ],
        "extensions": [
          ".mmt"
        ],
        "filenamePatterns": [
          "*.mmt.txt"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "typst",
        "aliases": ["Typst", "typst", "typ"],
        "extensions": [".typ"]
      }
    ],
    "grammars": [
      {
        "language": "mmt",
        "scopeName": "source.mmt",
        "path": "./syntaxes/mmt.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.typst": "typst",
          "meta.embedded.inline.typst": "typst"
        }
      },
      {
        "language": "typst",
        "scopeName": "source.typst",
        "path": "./vendor/tinymist-0.15.2/typst.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "[mmt]": {
        "editor.defaultColorDecorators": "never"
      }
    },
    "configuration": {
      "title": "MomoScript",
      "properties": {
        "mmt.server.path": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "mmt-lsp 的路径。留空时使用扩展内置的二进制文件。"
        },
        "mmt.typst.server.path": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Tinymist 的路径。留空时优先使用扩展内置的 Tinymist 二进制文件。"
        },
        "mmt.resourcePacks.manifestUrls": {
          "type": "array",
          "items": { "type": "string", "format": "uri" },
          "default": ["https://mms-pack.xiyihan.cn/ba_kivo/manifest.json"],
          "scope": "window",
          "description": "为资源感知语言功能加载的 HTTPS pack-v3 清单地址。"
        },
        "mmt.preview.onChange": {
          "type": "boolean",
          "default": true,
          "description": "文档变化后自动调度与对应修订版本绑定的预览。"
        },
        "mmt.resources.maxFileSizeMb": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "maximum": 64,
          "scope": "window",
          "description": "单个资源包文件允许加载的最大压缩体积，单位 MiB。"
        },
        "mmt.resources.maxProjectResources": {
          "type": "integer",
          "default": 128,
          "minimum": 1,
          "maximum": 512,
          "scope": "window",
          "description": "单次预览修订最多允许物化的资源数量。"
        },
        "mmt.resources.maxProjectSizeMb": {
          "type": "number",
          "default": 64,
          "minimum": 1,
          "maximum": 256,
          "scope": "window",
          "description": "单次预览修订允许占用的资源常驻与临时内存上限，单位 MiB。"
        }
      }
    }
  },
  "scripts": {
    "build:native": "node ./scripts/build-native.mjs",
    "build:wasm": "node ./scripts/build-wasm.mjs",
    "vendor:mmt-lsp": "npm run build:wasm && node ./scripts/promote-mmt-lsp-vendor.mjs",
    "build": "npm run build:native && npm run build:wasm && node ./scripts/build.mjs",
    "check": "tsc --noEmit",
    "test:grammar": "node ./scripts/test-grammar.mjs",
    "test:worker": "npm run build:wasm && node ./scripts/build.mjs && node ./scripts/test-worker.mjs",
    "test:tinymist-worker": "node ./scripts/build.mjs && node ./scripts/test-tinymist-worker.mjs",
    "test:tinymist-process": "node ./scripts/build.mjs && node ./dist/test/processClient.js",
    "test:desktop": "npm run build && xvfb-run -a node ./scripts/test-desktop.mjs",
    "test:web": "node ./scripts/require-tinymist-web.mjs && npm run build && vscode-test-web --browser=chromium --extensionDevelopmentPath=. --extensionTestsPath=dist/test/suite/index.js --headless=true --esm=true",
    "test:runtime-inventory": "node ./scripts/test-runtime-inventory.mjs",
    "test:project-lifecycle": "node ./scripts/test-project-lifecycle.mjs",
    "test:typst-project-state": "node ./scripts/test-typst-project-state.mjs",
    "test:typst-baseline": "node ./scripts/test-typst-language-baseline.mjs",
    "test:position-domains": "node ./scripts/test-position-domains.mjs",
    "test:runtime-characterization": "npm run test:runtime-inventory && npm run test:project-lifecycle && npm run test:typst-baseline",
    "test:capability-manifest": "node ./scripts/test-capability-manifest.mjs",
    "test:artifact-decision": "node ./scripts/test-artifact-decision.mjs",
    "test:runtime-identity": "node ./scripts/test-runtime-identity.mjs",
    "test:response-identity": "node ./scripts/test-response-identity.mjs",
    "test:capability-router": "node ./scripts/test-capability-router.mjs",
    "test:provider-descriptors": "node ./scripts/test-provider-descriptors.mjs"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.95.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/test-web": "^0.0.81",
    "esbuild": "^0.25.0",
    "vscode-oniguruma": "1.7.0",
    "vscode-textmate": "9.2.0",
    "typescript": "^5.7.0"
  }
}
