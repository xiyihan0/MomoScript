{
  "schemaVersion": 1,
  "scope": [
    "editors/vscode-web/src/main.ts",
    "editors/vscode-web/src/runtimeController.ts",
    "editors/vscode/src/tinymistClient.ts",
    "editors/vscode/src/tinymistProcessClient.ts",
    "editors/vscode/src/tinymistHostSession.ts",
    "editors/vscode/src/tinymistTransport.ts",
    "editors/vscode/src/typstProjectState.ts"
  ],
  "main": {
    "collections": [
      { "name": "previewProjects", "kind": "Map", "role": "latest prepared render project per logical source", "owner": "WebEditorRuntimeStores", "dispose": "controller teardown" },
      { "name": "packSourcesByNamespace", "kind": "Map", "role": "accepted resource pack source per namespace", "owner": "WebEditorRuntimeStores", "dispose": "controller teardown" },
      { "name": "latestProjectBySource", "kind": "Map", "role": "preview session, source version, and revision acceptance guard", "owner": "WebEditorRuntimeStores", "dispose": "closeSource or controller teardown" },
      { "name": "retiredProjectSessions", "kind": "Map<Set>", "role": "permanent preview-session retirement guard", "owner": "WebEditorRuntimeStores", "dispose": "closeSource or controller teardown" },
      { "name": "materializationControllers", "kind": "Map<AbortController>", "role": "latest materialization cancellation per source", "owner": "WebEditorRuntimeStores", "dispose": "superseding apply, closeSource, quiesce or controller teardown aborts" },
      { "name": "latestLanguageProjectionBySource", "kind": "Map", "role": "accepted language projection token per source", "owner": "WebEditorRuntimeStores", "dispose": "closeSource or controller teardown" },
      { "name": "typstRevisions", "kind": "Map", "role": "standalone Typst revision per source", "owner": "WebEditorRuntimeStores", "dispose": "controller teardown" },
      { "name": "typstProjects", "kind": "Map", "role": "standalone Typst project per source", "owner": "WebEditorRuntimeStores", "dispose": "controller teardown" },
      { "name": "acceptedPreviewLanguageProjects", "kind": "conditional Map", "role": "E2E-only accepted projection evidence", "owner": "WebEditorRuntimeStores", "dispose": "closeSource or controller teardown" },
      { "name": "retiredLanguageProjectionSessions", "kind": "Map<Set>", "role": "permanent language-projection session retirement guard", "owner": "WebEditorRuntimeStores", "dispose": "closeSource or controller teardown" },
      { "name": "requestedRenderTokens", "kind": "WeakSet", "role": "deduplicates preview render requests by accepted token identity", "owner": "WebEditorRuntimeStores", "dispose": "garbage collected with controller" },
      { "name": "renderRequestIdBySource", "kind": "Map", "role": "latest-wins render request sequence per source", "owner": "WebEditorRuntimeStores", "dispose": "closeSource or controller teardown" },
      { "name": "persistenceByUri", "kind": "Map<Promise>", "role": "serialized document persistence queue per URI", "owner": "WebEditorRuntimeStores", "dispose": "entry removed on settlement; quiesce drains; controller teardown clears" }
    ],
    "listeners": [
      { "name": "panelVisibilityRegistration", "source": "part visibility", "owner": "EditorRuntimeController" },
      { "name": "sidebarVisibilityRegistration", "source": "part visibility", "owner": "EditorRuntimeController" },
      { "name": "typstDocumentOpenRegistration", "source": "workspace document open", "owner": "EditorRuntimeController subscription" },
      { "name": "typstEditorActivationRegistration", "source": "active editor change", "owner": "EditorRuntimeController subscription" },
      { "name": "mmt/typstProjectUpdated", "source": "MMT client notification", "owner": "EditorRuntimeController subscription" },
      { "name": "mmt/typstProjectClosed", "source": "MMT client notification", "owner": "EditorRuntimeController subscription" },
      { "name": "documentConfigCommandRegistration", "source": "command", "owner": "EditorRuntimeController subscription" },
      { "name": "previewCommandRegistration", "source": "command", "owner": "EditorRuntimeController subscription" },
      { "name": "previewPanelDisposeRegistration", "source": "webview panel disposal", "owner": "EditorRuntimeController plus panel callback self-release" },
      { "name": "previewPanelMessageRegistration", "source": "webview message", "owner": "EditorRuntimeController plus panel callback self-release" },
      { "name": "packConfigRegistration", "source": "configuration change", "owner": "EditorRuntimeController subscription" },
      { "name": "previewConfigRegistration", "source": "configuration change", "owner": "EditorRuntimeController subscription" },
      { "name": "markerEditingRegistration", "source": "model content listeners", "owner": "EditorRuntimeController wrapper drains child registrations" },
      { "name": "documentPersistenceRegistration", "source": "document change", "owner": "EditorRuntimeController subscription" },
      { "name": "typstDocumentChangeRegistration", "source": "document change", "owner": "EditorRuntimeController subscription" },
      { "name": "beforeunload", "source": "window", "owner": "EditorRuntimeController via ownEventListener" },
      { "name": "hmr", "source": "import.meta.hot", "owner": "Vite HMR callback delegates to EditorRuntimeController" },
      { "name": "layout activity click", "source": "DOM", "owner": "layout disposable registered in EditorRuntimeController" },
      { "name": "settings controls", "source": "DOM and configuration", "owner": "settings view disposable" },
      { "name": "preview webview controls", "source": "isolated webview DOM", "owner": "webview document lifecycle" },
      { "name": "AVIFS abort", "source": "AbortSignal", "owner": "one-shot decode promise removes listener on settlement" }
    ],
    "timers": [
      { "name": "document projection catch-up", "kind": "one-shot debounce", "owner": "persistence queue promise", "cleanup": "settles into queue finally" },
      { "name": "download object URL revoke", "kind": "zero-delay one-shot", "owner": "downloadBlob call", "cleanup": "callback revokes URL" },
      { "name": "HMR graceful fallback", "kind": "deadline", "owner": "EditorRuntimeController", "cleanup": "cleared when graceful disposal wins" }
    ],
    "workersAndProcesses": [
      { "name": "TextEditorWorker", "kind": "Worker", "owner": "Monaco worker factory", "dispose": "Monaco API lifecycle" },
      { "name": "TextMateWorker", "kind": "Worker", "owner": "Monaco worker factory", "dispose": "Monaco API lifecycle" },
      { "name": "OutputLinkDetectionWorker", "kind": "Worker", "owner": "Monaco worker factory", "dispose": "Monaco API lifecycle" },
      { "name": "Tinymist Worker", "kind": "Worker", "owner": "Tinymist handle registered in EditorRuntimeController", "dispose": "graceful handle.dispose; HMR/unload terminate fallback" },
      { "name": "MMT Worker", "kind": "Worker", "owner": "MMT handle registered in EditorRuntimeController", "dispose": "graceful handle.dispose; HMR/unload terminate fallback" },
      { "name": "AVIFS decoder", "kind": "Worker", "owner": "single decode promise", "dispose": "terminate on success, error, or abort" },
      { "name": "native Tinymist", "kind": "process", "owner": "TinymistProcessClient in Desktop extension", "dispose": "shutdown/exit then kill fallback" },
      { "name": "native MMT LSP", "kind": "process", "owner": "VS Code LanguageClient in Desktop extension", "dispose": "LanguageClient stop" }
    ],
    "dispose": {
      "primaryOwner": "EditorRuntimeController",
      "registration": "controller own(resource) or subscribe(subscription)",
      "order": "sequential reverse acquisition",
      "startupFailure": "controller start rolls back and terminates on deadline",
      "hmr": "controller dispose with graceful deadline and termination fallback",
      "unload": "controller terminateAndDispose terminates synchronously",
      "idempotence": "EditorRuntimeController shares startup, quiesce and disposal promises"
    }
  },
  "duplicatedClientState": [],
  "sharedHostSessionState": [
    { "name": "handlers", "role": "host-neutral notification and project event subscriptions" },
    { "name": "capabilityRegistry", "role": "shared initialize and dynamic capability state, including semantic-token legend" },
    { "name": "ready", "role": "initialized backend and replay completion" },
    { "name": "stopped", "role": "terminal session disposal guard" },
    { "name": "restarting", "role": "single serialized recovery promise" }
  ],
  "hostSessionLifecycle": {
    "owner": "TinymistHostSession",
    "recovery": "one boot promise activates one newer generation and replays latest complete projects before ready",
    "gracefulDispose": "stop marks terminal before awaiting transport shutdown",
    "immediateDispose": "terminate marks the shared session terminal and synchronously terminates the active transport",
    "idempotence": "stop and terminate share one terminal guard"
  },
  "sharedTransportState": [
    { "name": "nextId", "role": "JSON-RPC request sequence" },
    { "name": "pending", "role": "bounded pending requests and deadlines" },
    { "name": "currentGeneration", "role": "monotonic backend generation" },
    { "name": "connection", "role": "active Worker or process JSON-RPC connection" }
  ],
  "sharedProjectState": [
    { "name": "openFiles", "role": "open virtual file revisions" },
    { "name": "projectFiles", "role": "current complete project files" },
    { "name": "appliedProjectFiles", "role": "last applied file generation" },
    { "name": "retainedProjectFiles", "role": "bounded retained file generations" },
    { "name": "projectsByEntry", "role": "latest complete project per source" },
    { "name": "latestProjectionBySource", "role": "accepted session and revision" },
    { "name": "retiredSessionsBySource", "role": "permanently retired sessions" },
    { "name": "appliedProjectionBySource", "role": "last applied session and revision" },
    { "name": "scheduledFileCloses", "role": "bounded close ownership" },
    { "name": "scheduledCloseFallbacks", "role": "close-grace deadlines" },
    { "name": "projectPrimeTimers", "role": "prime debounce timers" },
    { "name": "projectPrimeQueue", "role": "latest-wins prime queue" },
    { "name": "projectPrimeInFlight", "role": "cancellable prime work" },
    { "name": "projectPrimeByEntry", "role": "exact-entry prime barriers" },
    { "name": "requestControllers", "role": "bounded cancellable feature requests" }
  ],
  "processOnlyState": [
    { "name": "buffer", "role": "Content-Length framed byte buffer in process connection" }
  ],
  "workerOnlyState": []
}
