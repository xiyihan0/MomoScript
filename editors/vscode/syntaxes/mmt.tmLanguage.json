{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "MomoScript",
  "scopeName": "source.mmt",
  "patterns": [
    { "include": "#comments" },
    { "include": "#typst-regions" },
    { "include": "#directives" },
    { "include": "#statements" },
    { "include": "#macros" },
    { "include": "#strings" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.mmt", "match": "//.*$" }
      ]
    },
    "typst-directives": {
      "patterns": [
        {
          "name": "meta.directive.typst.block.mmt",
          "begin": "^(\\s*)(@typ)\\s*$",
          "beginCaptures": { "2": { "name": "keyword.control.directive.mmt" } },
          "end": "^(\\s*)(@end)\\b",
          "endCaptures": { "2": { "name": "keyword.control.directive.mmt" } },
          "contentName": "meta.embedded.block.typst",
          "patterns": [{ "include": "source.typst" }]
        },
        {
          "name": "meta.directive.typst.inline.mmt",
          "begin": "^(\\s*)(@typ)(\\s*:\\s*)",
          "beginCaptures": { "2": { "name": "keyword.control.directive.mmt" } },
          "end": "$",
          "contentName": "meta.embedded.inline.typst",
          "patterns": [{ "include": "source.typst" }]
        }
      ]
    },
    "explicit-body-overrides": {
      "patterns": [
        {
          "name": "meta.body.typst.explicit-override.mmt",
          "begin": "^(\\s*(?:[><]\\s+.*?(?<!:):(?!:)|-)\\s*)(T)(\"{3,})",
          "beginCaptures": {
            "1": { "name": "keyword.operator.statement.mmt" },
            "2": { "name": "storage.modifier.body-mode.mmt" },
            "3": { "name": "punctuation.definition.string.begin.typst" }
          },
          "end": "\\3\\s*$",
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.typst" } },
          "contentName": "meta.embedded.block.typst",
          "patterns": [{ "include": "#macros" }, { "include": "source.typst" }]
        },
        {
          "name": "meta.body.typst-raw.explicit-override.mmt",
          "begin": "^(\\s*(?:[><]\\s+.*?(?<!:):(?!:)|-)\\s*)(rT)(\"{3,})",
          "beginCaptures": {
            "1": { "name": "keyword.operator.statement.mmt" },
            "2": { "name": "storage.modifier.body-mode.mmt" },
            "3": { "name": "punctuation.definition.string.begin.typst" }
          },
          "end": "\\3\\s*$",
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.typst" } },
          "contentName": "meta.embedded.block.typst",
          "patterns": [{ "include": "source.typst" }]
        },
        {
          "name": "meta.body.text.explicit-override.mmt",
          "begin": "^(\\s*(?:[><]\\s+.*?(?<!:):(?!:)|-)\\s*)(t)(\"{3,})",
          "beginCaptures": {
            "1": { "name": "keyword.operator.statement.mmt" },
            "2": { "name": "storage.modifier.body-mode.mmt" },
            "3": { "name": "punctuation.definition.string.begin.mmt" }
          },
          "end": "\\3\\s*$",
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.mmt" } },
          "patterns": [{ "include": "#macros" }]
        },
        {
          "name": "meta.body.text-raw.explicit-override.mmt",
          "begin": "^(\\s*(?:[><]\\s+.*?(?<!:):(?!:)|-)\\s*)(rt)(\"{3,})",
          "beginCaptures": {
            "1": { "name": "keyword.operator.statement.mmt" },
            "2": { "name": "storage.modifier.body-mode.mmt" },
            "3": { "name": "punctuation.definition.string.begin.mmt" }
          },
          "end": "\\3\\s*$",
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.mmt" } }
        }
      ]
    },
    "statement-patch": {
      "patterns": [
        {
          "name": "meta.statement.patch.mmt",
          "begin": "\\G(\\()",
          "beginCaptures": { "1": { "name": "meta.brace.round.typst" } },
          "end": "\\)",
          "endCaptures": { "0": { "name": "meta.brace.round.typst" } },
          "contentName": "meta.embedded.inline.typst meta.expr.call.typst",
          "patterns": [{ "include": "#typst-patch-arguments" }]
        }
      ]
    },
    "explicit-body-suffix": {
      "patterns": [
        {
          "name": "meta.body.typst.explicit-override.mmt",
          "begin": "(?<=\\))\\s*(T)(\"{3,})",
          "beginCaptures": {
            "1": { "name": "storage.modifier.body-mode.mmt" },
            "2": { "name": "punctuation.definition.string.begin.typst" }
          },
          "end": "\\2\\s*$",
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.typst" } },
          "contentName": "meta.embedded.block.typst",
          "patterns": [{ "include": "#macros" }, { "include": "source.typst" }]
        },
        {
          "name": "meta.body.typst-raw.explicit-override.mmt",
          "begin": "(?<=\\))\\s*(rT)(\"{3,})",
          "beginCaptures": {
            "1": { "name": "storage.modifier.body-mode.mmt" },
            "2": { "name": "punctuation.definition.string.begin.typst" }
          },
          "end": "\\2\\s*$",
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.typst" } },
          "contentName": "meta.embedded.block.typst",
          "patterns": [{ "include": "source.typst" }]
        },
        {
          "name": "meta.body.text.explicit-override.mmt",
          "begin": "(?<=\\))\\s*(t)(\"{3,})",
          "beginCaptures": {
            "1": { "name": "storage.modifier.body-mode.mmt" },
            "2": { "name": "punctuation.definition.string.begin.mmt" }
          },
          "end": "\\2\\s*$",
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.mmt" } },
          "patterns": [{ "include": "#macros" }]
        },
        {
          "name": "meta.body.text-raw.explicit-override.mmt",
          "begin": "(?<=\\))\\s*(rt)(\"{3,})",
          "beginCaptures": {
            "1": { "name": "storage.modifier.body-mode.mmt" },
            "2": { "name": "punctuation.definition.string.begin.mmt" }
          },
          "end": "\\2\\s*$",
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.mmt" } }
        }
      ]
    },
    "patched-explicit-body-overrides": {
      "patterns": [
        {
          "name": "meta.statement.patched-explicit-body.mmt",
          "begin": "^(\\s*(?:[><]\\s+.*?(?<!:):(?!:)|-)\\s*)(?=\\(.*\\)\\s*(?:T|rT|t|rt)\"{3,})",
          "beginCaptures": { "1": { "name": "keyword.operator.statement.mmt" } },
          "end": "$",
          "patterns": [
            { "include": "#statement-patch" },
            { "include": "#explicit-body-suffix" }
          ]
        }
      ]
    },
    "typst-regions": {
      "patterns": [
        { "include": "#typst-directives" },
        { "include": "#patched-explicit-body-overrides" },
        {
          "name": "meta.mode.typst.mmt",
          "begin": "^(\\s*)(@mode)(\\s*:\\s*)(?:T|typst)\\s*$",
          "beginCaptures": { "2": { "name": "keyword.control.directive.mmt" } },
          "end": "(?=^\\s*@mode\\b)|\\z",
          "patterns": [
            { "include": "#comments" },
            { "include": "#typst-directives" },
            { "include": "#explicit-body-overrides" },
            {
              "name": "meta.body.typst.inherited-fence.mmt",
              "begin": "^(\\s*(?:[><]\\s+.*?(?<!:):(?!:)|-)\\s*)(\"{3,})",
              "beginCaptures": {
                "1": { "name": "keyword.operator.statement.mmt" },
                "2": { "name": "punctuation.definition.string.begin.typst" }
              },
              "end": "\\2\\s*$",
              "endCaptures": { "0": { "name": "punctuation.definition.string.end.typst" } },
              "contentName": "meta.embedded.block.typst",
              "patterns": [{ "include": "#macros" }, { "include": "source.typst" }]
            },
            {
              "name": "meta.body.typst.mode-line.mmt",
              "begin": "^(\\s*(?:[><]\\s+.*?(?<!:):(?!:)|-)\\s*)",
              "beginCaptures": { "1": { "name": "keyword.operator.statement.mmt" } },
              "end": "$",
              "contentName": "meta.embedded.inline.typst",
              "patterns": [
                { "include": "#statement-patch" },
                { "include": "#explicit-body-suffix" },
                { "include": "#macros" },
                { "include": "source.typst" }
              ]
            },
            { "include": "#directives" }
          ]
        },
        {
          "name": "meta.mode.typst-raw.mmt",
          "begin": "^(\\s*)(@mode)(\\s*:\\s*)(?:rT|raw-typst)\\s*$",
          "beginCaptures": { "2": { "name": "keyword.control.directive.mmt" } },
          "end": "(?=^\\s*@mode\\b)|\\z",
          "patterns": [
            { "include": "#comments" },
            { "include": "#typst-directives" },
            { "include": "#explicit-body-overrides" },
            {
              "name": "meta.body.typst-raw.inherited-fence.mmt",
              "begin": "^(\\s*(?:[><]\\s+.*?(?<!:):(?!:)|-)\\s*)(\"{3,})",
              "beginCaptures": {
                "1": { "name": "keyword.operator.statement.mmt" },
                "2": { "name": "punctuation.definition.string.begin.typst" }
              },
              "end": "\\2\\s*$",
              "endCaptures": { "0": { "name": "punctuation.definition.string.end.typst" } },
              "contentName": "meta.embedded.block.typst",
              "patterns": [{ "include": "source.typst" }]
            },
            {
              "name": "meta.body.typst-raw.mode-line.mmt",
              "begin": "^(\\s*(?:[><]\\s+.*?(?<!:):(?!:)|-)\\s*)",
              "beginCaptures": { "1": { "name": "keyword.operator.statement.mmt" } },
              "end": "$",
              "contentName": "meta.embedded.inline.typst",
              "patterns": [
                { "include": "#statement-patch" },
                { "include": "#explicit-body-suffix" },
                { "include": "source.typst" }
              ]
            },
            { "include": "#directives" }
          ]
        },
        {
          "name": "meta.body.typst.inline.mmt",
          "begin": "^(\\s*(?:[><]\\s+.*:(?!:)|-)\\s*)(T)(\"{3,})(?=.*\\3\\s*$)",
          "beginCaptures": {
            "1": { "name": "keyword.operator.statement.mmt" },
            "2": { "name": "storage.modifier.body-mode.mmt" },
            "3": { "name": "punctuation.definition.string.begin.typst" }
          },
          "end": "\\3\\s*$",
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.typst" } },
          "contentName": "meta.embedded.inline.typst",
          "patterns": [{ "include": "#macros" }, { "include": "source.typst" }]
        },
        {
          "name": "meta.body.typst-raw.inline.mmt",
          "begin": "^(\\s*(?:[><]\\s+.*:(?!:)|-)\\s*)(rT)(\"{3,})(?=.*\\3\\s*$)",
          "beginCaptures": {
            "1": { "name": "keyword.operator.statement.mmt" },
            "2": { "name": "storage.modifier.body-mode.mmt" },
            "3": { "name": "punctuation.definition.string.begin.typst" }
          },
          "end": "\\3\\s*$",
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.typst" } },
          "contentName": "meta.embedded.inline.typst",
          "patterns": [{ "include": "source.typst" }]
        },
        {
          "name": "meta.body.typst.block.mmt",
          "begin": "^(\\s*(?:[><]\\s+.*:(?!:)|-)\\s*)(T)(\"{3,})\\s*$",
          "beginCaptures": {
            "1": { "name": "keyword.operator.statement.mmt" },
            "2": { "name": "storage.modifier.body-mode.mmt" },
            "3": { "name": "punctuation.definition.string.begin.typst" }
          },
          "end": "^\\s*\\3\\s*$",
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.typst" } },
          "contentName": "meta.embedded.block.typst",
          "patterns": [{ "include": "#macros" }, { "include": "source.typst" }]
        },
        {
          "name": "meta.body.typst-raw.block.mmt",
          "begin": "^(\\s*(?:[><]\\s+.*:(?!:)|-)\\s*)(rT)(\"{3,})\\s*$",
          "beginCaptures": {
            "1": { "name": "keyword.operator.statement.mmt" },
            "2": { "name": "storage.modifier.body-mode.mmt" },
            "3": { "name": "punctuation.definition.string.begin.typst" }
          },
          "end": "^\\s*\\3\\s*$",
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.typst" } },
          "contentName": "meta.embedded.block.typst",
          "patterns": [{ "include": "source.typst" }]
        },
        {
          "name": "meta.statement.patched-line.mmt",
          "begin": "^(\\s*[><-]\\s*)(?=\\()",
          "beginCaptures": { "1": { "name": "keyword.operator.statement.mmt" } },
          "end": "$",
          "patterns": [{ "include": "#statement-patch" }]
        },
        {
          "name": "meta.resource.patch.mmt",
          "begin": "(?<=:\\])(\\()",
          "beginCaptures": {
            "1": { "name": "meta.brace.round.typst" }
          },
          "end": "\\)",
          "endCaptures": { "0": { "name": "meta.brace.round.typst" } },
          "contentName": "meta.embedded.inline.typst meta.expr.call.typst",
          "patterns": [{ "include": "#typst-patch-arguments" }]
        }
      ]
    },
    "typst-patch-parentheses": {
      "patterns": [
        {
          "name": "meta.brace.round.typst meta.expr.call.typst",
          "begin": "\\(",
          "end": "\\)",
          "contentName": "meta.embedded.inline.typst meta.expr.call.typst",
          "patterns": [{ "include": "#typst-patch-arguments" }]
        }
      ]
    },
    "typst-patch-arguments": {
      "patterns": [
        {
          "match": "([A-Za-z_][A-Za-z0-9_-]*)(\\s*)(:)",
          "captures": {
            "1": { "name": "variable.other.readwrite.typst" },
            "3": { "name": "punctuation.separator.colon.typst" }
          }
        },
        { "include": "#typst-patch-parentheses" },
        { "include": "source.typst#expression" }
      ]
    },
    "directives": {
      "patterns": [
        {
          "name": "meta.directive.mmt",
          "match": "^\\s*(@(?:actor|asset|typ|reply|bond|mode|end))\\b",
          "captures": { "1": { "name": "keyword.control.directive.mmt" } }
        }
      ]
    },
    "statements": {
      "patterns": [
        {
          "name": "meta.statement.chat.mmt",
          "match": "^\\s*([><-])(?:\\s*(\\([^\\n]*\\)))?",
          "captures": {
            "1": { "name": "keyword.operator.statement.mmt" },
            "2": { "name": "meta.parameters.mmt" }
          }
        }
      ]
    },
    "macros": {
      "patterns": [
        {
          "name": "meta.macro.sticker.mmt",
          "begin": "\\[:",
          "beginCaptures": { "0": { "name": "punctuation.definition.macro.begin.mmt" } },
          "end": ":\\]",
          "endCaptures": { "0": { "name": "punctuation.definition.macro.end.mmt" } },
          "patterns": [
            { "match": "\\\\.", "name": "constant.character.escape.mmt" },
            { "include": "#strings" }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        { "name": "string.quoted.double.mmt", "begin": "\"", "end": "\"", "patterns": [{ "match": "\\\\.", "name": "constant.character.escape.mmt" }] },
        { "name": "string.quoted.single.mmt", "begin": "'", "end": "'", "patterns": [{ "match": "\\\\.", "name": "constant.character.escape.mmt" }] }
      ]
    }
  }
}
