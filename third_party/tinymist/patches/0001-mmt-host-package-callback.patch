+/// A non-blocking callback emitted when a fully specified package is absent.
+pub type PackageMissingCallback = Arc<dyn Fn(PackageSpec) + Send + Sync>;
+
+/// Immutable host package activations shared by compiler snapshots.
+#[derive(Default)]
+pub struct HostPackageMap {
+    packages: RwLock<HashMap<PackageSpec, HostPackageActivation>>,
+    revision: AtomicUsize,
+}
+
+#[derive(Clone)]
+struct HostPackageActivation {
+    root: Arc<Path>,
+    #[allow(dead_code)]
+    package_generation: EcoString,
+    #[allow(dead_code)]
+    files_digest: EcoString,
+}
+
+impl HostPackageMap {
+    /// Returns the active immutable root for a package.
+    pub fn resolve(&self, spec: &PackageSpec) -> Option<Arc<Path>> {
+        self.packages.read().get(spec).map(|entry| entry.root.clone())
+    }
+
+    /// Derives the internal root for host-injected immutable package files.
+    pub fn root_for(spec: &PackageSpec, files_digest: &str) -> Result<Arc<Path>, PackageError> {
+        if files_digest.len() != 64 || !files_digest.bytes().all(|byte| byte.is_ascii_hexdigit()) {
+            return Err(PackageError::Other(Some(eco_format!(
+                "invalid host package files digest"
+            ))));
+        }
+        Ok(PathBuf::from("/__mmt_typst_packages")
+            .join(spec.namespace.as_str())
+            .join(spec.name.as_str())
+            .join(spec.version.to_string())
+            .join(files_digest.to_ascii_lowercase())
+            .into())
+    }
+
+    /// Atomically activates a host-prepared immutable package generation.
+    pub fn activate(
+        &self,
+        spec: PackageSpec,
+        package_generation: &str,
+        files_digest: &str,
+    ) -> Result<Arc<Path>, PackageError> {
+        if package_generation.is_empty()
+            || package_generation.len() > 128
+            || !package_generation
+                .bytes()
+                .all(|byte| byte.is_ascii_alphanumeric() || matches!(byte, b'-' | b'_' | b'.'))
+        {
+            return Err(PackageError::Other(Some(eco_format!(
+                "invalid host package generation"
+            ))));
+        }
+        let root = Self::root_for(&spec, files_digest)?;
+        let activation = HostPackageActivation {
+            root: root.clone(),
+            package_generation: package_generation.into(),
+            files_digest: files_digest.into(),
+        };
+        self.packages.write().insert(spec, activation);
+        let previous = self.revision.fetch_add(1, Ordering::AcqRel);
+        if previous == usize::MAX {
+            self.revision.store(1, Ordering::Release);
+        }
+        Ok(root)
+    }
+
+    /// Returns a stable non-zero revision for compiler cache invalidation.
+    pub fn revision(&self) -> NonZeroUsize {
+        NonZeroUsize::new(self.revision.load(Ordering::Acquire).saturating_add(1))
+            .unwrap_or(NonZeroUsize::MIN)
+    }
+}
