+//! Host-mediated Typst package callback protocol.
+
+use std::collections::{HashMap, HashSet};
+use std::path::{Component, Path};
+use std::sync::Arc;
+
+use base64::Engine;
+use lsp_types::{notification::Notification, request::Request};
+use serde::{Deserialize, Serialize};
+use sync_ls::{Initializer, LspResult, RequestId, ServiceState, lsp};
+use tinymist_project::HostPackageMemoryEvent;
+use tinymist_project::world::package::registry::HostPackageMap;
+use tinymist_project::world::package::PackageSpec;
+use typst::diag::FileResult;
+use typst::foundations::Bytes;
+use typst::syntax::{FileId, RootedPath, VirtualPath, VirtualRoot};
+
+use crate::project::LspInterrupt;
+use crate::ServerState;
+
+/// Versioned context notification sent before compiling a project snapshot.
+pub enum TypstPackageContextNotification {}
+
+impl Notification for TypstPackageContextNotification {
+    type Params = TypstPackageContext;
+    const METHOD: &'static str = "mmt/typstPackageContext.v1";
+}
+
+
+/// Versioned package request emitted by Tinymist.
+pub enum TypstPackageRequest {}
+
+impl Request for TypstPackageRequest {
+    type Params = TypstPackageRequestParams;
+    type Result = TypstPackageResponse;
+    const METHOD: &'static str = "mmt/typstPackageRequest.v1";
+}
+
+/// Identity of the active host project snapshot.
+#[derive(Debug, Clone, Hash, PartialEq, Eq, Deserialize, Serialize)]
+pub struct TypstPackageContext {
+    pub backend_generation: u64,
+    pub typst_project_snapshot_key: String,
+}
+
+/// A safe, fully specified Typst package identity.
+#[derive(Debug, Clone, PartialEq, Eq, Deserialize, Serialize)]
+pub struct HostPackageSpec {
+    pub namespace: String,
+    pub name: String,
+    pub version: String,
+}
+
+impl From<&PackageSpec> for HostPackageSpec {
+    fn from(spec: &PackageSpec) -> Self {
+        Self {
+            namespace: spec.namespace.to_string(),
+            name: spec.name.to_string(),
+            version: spec.version.to_string(),
+        }
+    }
+}
+
+/// Parameters sent to the host package service.
+#[derive(Debug, Clone, PartialEq, Eq, Deserialize, Serialize)]
+pub struct TypstPackageRequestParams {
+    pub request_id: String,
+    pub backend_generation: u64,
+    pub typst_project_snapshot_key: String,
+    pub package_spec: HostPackageSpec,
+    #[serde(skip_serializing_if = "Option::is_none")]
+    pub requested_path: Option<String>,
+}
+
+/// Host outcome for one logical package request.
+#[derive(Debug, Clone, PartialEq, Eq, Deserialize, Serialize)]
+#[serde(tag = "status")]
+pub enum TypstPackageResponse {
+    Ready {
+        request_id: String,
+        package_generation: String,
+        files_digest: String,
+        files: Vec<HostPackageFile>,
+    },
+    Unavailable {
+        request_id: String,
+        reason: String,
+        retryable: bool,
+    },
+    Cancelled {
+        request_id: String,
+    },
+}
+
+/// One safe package-relative file supplied by the host.
+#[derive(Debug, Clone, PartialEq, Eq, Deserialize, Serialize)]
+pub struct HostPackageFile {
+    pub path: String,
+    pub content_base64: String,
+}
+
+
+/// Missing-package event emitted from synchronous compiler evaluation.
+#[derive(Debug)]
+pub(crate) struct PackageMissingEvent {
+    pub spec: Option<PackageSpec>,
+}
+
+#[derive(Debug)]
+struct PendingPackageRequest {
+    rpc_id: RequestId,
+    context: TypstPackageContext,
+    spec: PackageSpec,
+}
+
+/// State for non-blocking package requests. It owns no package bytes.
+#[derive(Default)]
+pub(crate) struct PackageCallbackState {
+    context: Option<TypstPackageContext>,
+    pub(crate) host_packages: Arc<HostPackageMap>,
+    next_request_id: u64,
+    pending: HashMap<String, PendingPackageRequest>,
+    requested: HashSet<(TypstPackageContext, PackageSpec)>,
+}
+
+impl ServerState {
+    pub(crate) fn package_context_notification(
+        &mut self,
+        context: TypstPackageContext,
+    ) -> LspResult<()> {
+        if context.backend_generation == 0 || context.typst_project_snapshot_key.is_empty() {
+            return Err(sync_ls::invalid_params(
+                "package context requires a positive backend generation and project snapshot key",
+            ));
+        }
+        #[cfg(feature = "system")]
+        let initial_context = self.package_callback.context.is_none();
+        if self.package_callback.context.as_ref() == Some(&context) {
+            return Ok(());
+        }
+
+        self.package_callback
+            .requested
+            .retain(|(seen_context, _)| seen_context == &context);
+        let client = self.client.clone().to_untyped();
+        for (_, pending) in self.package_callback.pending.drain() {
+            client.send_notification_(lsp::Notification::new(
+                "$/cancelRequest".to_owned(),
+                serde_json::json!({ "id": pending.rpc_id }),
+            ));
+        }
+        self.package_callback.context = Some(context);
+        #[cfg(feature = "system")]
+        if initial_context {
+            self.reload_projects()
+                .map_err(|error| sync_ls::internal_error(format!("cannot activate host package registry: {error}")))?;
+        }
+        Ok(())
+    }
+
+
+    pub(crate) fn package_missing_event<T: Initializer<S = Self>>(
+        mut state: ServiceState<T, T::S>,
+        event: PackageMissingEvent,
+    ) -> anyhow::Result<()> {
+        let Some(ready) = state.ready() else {
+            return Ok(());
+        };
+        if let Some(spec) = event.spec {
+            ready.request_missing_package(spec);
+        }
+        Ok(())
+    }
+
+    fn request_missing_package(&mut self, spec: PackageSpec) {
+        if spec.namespace.as_str() != "preview" {
+            return;
+        }
+        let Some(context) = self.package_callback.context.clone() else {
+            return;
+        };
+        if !self
+            .package_callback
+            .requested
+            .insert((context.clone(), spec.clone()))
+        {
+            return;
+        }
+
+        self.package_callback.next_request_id = self
+            .package_callback
+            .next_request_id
+            .checked_add(1)
+            .unwrap_or(1);
+        let request_id = format!("mmt-package-{}", self.package_callback.next_request_id);
+        let params = TypstPackageRequestParams {
+            request_id: request_id.clone(),
+            backend_generation: context.backend_generation,
+            typst_project_snapshot_key: context.typst_project_snapshot_key.clone(),
+            package_spec: HostPackageSpec::from(&spec),
+            requested_path: None,
+        };
+        let callback_request_id = request_id.clone();
+        let rpc_id = self.client.send_lsp_request::<TypstPackageRequest>(
+            params,
+            move |state, response| {
+                state.handle_package_response(&callback_request_id, response);
+            },
+        );
+        self.package_callback.pending.insert(
+            request_id,
+            PendingPackageRequest {
+                rpc_id,
+                context,
+                spec,
+            },
+        );
+    }
+
+    fn handle_package_response(&mut self, request_id: &str, response: lsp::Response) {
+        let Some(pending) = self.package_callback.pending.remove(request_id) else {
+            return;
+        };
+        if self.package_callback.context.as_ref() != Some(&pending.context) {
+            return;
+        }
+        let Some(result) = response.result else {
+            if let Some(error) = response.error {
+                log::warn!("host package request {request_id} failed: {}", error.message);
+            }
+            return;
+        };
+        let outcome = match serde_json::from_value::<TypstPackageResponse>(result) {
+            Ok(outcome) => outcome,
+            Err(error) => {
+                log::warn!("invalid host package response for {request_id}: {error}");
+                return;
+            }
+        };
+
+        match outcome {
+            TypstPackageResponse::Ready {
+                request_id: response_id,
+                package_generation,
+                files_digest,
+                files,
+            } if response_id == request_id => {
+                #[cfg(any(feature = "system", feature = "web"))]
+                {
+                    if files.is_empty() {
+                        log::warn!("host package Ready response has no files for {request_id}");
+                        return;
+                    }
+                    if let Err(error) = HostPackageMap::root_for(&pending.spec, &files_digest) {
+                        log::warn!("invalid host package root for {request_id}: {error}");
+                        return;
+                    }
+                    let mut seen = HashSet::new();
+                    let mut inserts = Vec::with_capacity(files.len());
+                    for file in files {
+                        let relative = Path::new(&file.path);
+                        if file.path.is_empty()
+                            || file.path.contains('\\')
+                            || relative.is_absolute()
+                            || !relative.components().all(|component| matches!(component, Component::Normal(_)))
+                            || !seen.insert(file.path.clone())
+                        {
+                            log::warn!("unsafe or duplicate package-relative path for {request_id}");
+                            return;
+                        }
+                        let content = match base64::engine::general_purpose::STANDARD.decode(&file.content_base64) {
+                            Ok(content) => content,
+                            Err(_) => {
+                                log::warn!("invalid base64 package file for {request_id}");
+                                return;
+                            }
+                        };
+                        let virtual_path = match VirtualPath::new(&file.path) {
+                            Ok(path) => path,
+                            Err(_) => {
+                                log::warn!("invalid package virtual path for {request_id}");
+                                return;
+                            }
+                        };
+                        let file_id = FileId::new(RootedPath::new(
+                            VirtualRoot::Package(pending.spec.clone()),
+                            virtual_path,
+                        ));
+                        inserts.push((file_id, FileResult::Ok(Bytes::new(content)).into()));
+                    }
+                    self.project.interrupt(LspInterrupt::HostPackage(HostPackageMemoryEvent {
+                        host_packages: self.package_callback.host_packages.clone(),
+                        spec: pending.spec,
+                        package_generation,
+                        files_digest,
+                        inserts,
+                    }));
+                    self.schedule_async();
+                }
+            }
+            TypstPackageResponse::Unavailable {
+                request_id: response_id,
+                reason,
+                retryable,
+            } if response_id == request_id => {
+                log::info!(
+                    "host package unavailable for {request_id}: {reason} (retryable={retryable})"
+                );
+            }
+            TypstPackageResponse::Cancelled {
+                request_id: response_id,
+            } if response_id == request_id => {
+                log::debug!("host package request {request_id} was cancelled");
+            }
+            _ => {
+                log::warn!("host package response request id mismatch for {request_id}");
+            }
+        }
+    }
+}
