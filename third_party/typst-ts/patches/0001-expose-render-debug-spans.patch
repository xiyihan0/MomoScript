+    pub fn resolve_main_spans(&self, span_ids_json: String) -> Result<String, JsValue> {
+        let span_ids: Vec<String> =
+            serde_json::from_str(&span_ids_json).map_err(|error| error.to_string())?;
+        let world = &self.graph.snap.world;
+        let main = world.main();
+        let resolved = span_ids.into_iter().filter_map(|span_id| {
+            let raw = u64::from_str_radix(span_id.trim_start_matches("0x"), 16).ok()?;
+            let span = Span::from_raw(NonZeroU64::new(raw)?);
+            if span.id() != Some(main) {
+                return None;
+            }
+            let range = world.range(span)?;
+            Some(serde_json::json!({
+                "span": span_id,
+                "start": range.start,
+                "end": range.end,
+            }))
+        });
+        serde_json::to_string(&resolved.collect::<Vec<_>>())
+            .map_err(|error| error.to_string().into())
+    }
+    pub fn render_svg_with_debug_spans(&mut self) -> Result<String, JsValue> {
+        let doc = self
+            .do_compile_paged()?
+            .ok_or_else(|| error_once!("document is not compiled"))?;
+        type DebugSvgExporter = reflexo_vec2svg::SvgExporter<DebugSvgExportFeature>;
+        let mut typst2vec = reflexo_typst2vec::pass::Typst2VecPass::default();
+        typst2vec.spans.set_should_attach_debug_info(true);
+        let pages = typst2vec.paged(&doc);
+        let mut module = typst2vec.finalize();
+        module.prepare_glyphs();
+        Ok(DebugSvgExporter::render_flat_svg(
+            &module,
+            &pages,
+            None,
+        ))
+    }
 
