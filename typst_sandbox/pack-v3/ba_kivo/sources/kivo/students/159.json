      "file": "//static.kivo.wiki/voices/students/%E6%97%97%E8%A7%81%20%E7%BB%98%E9%87%8C%E9%A6%99/original/jp/erika_exskill_level_1.ogg"
    },
    {
      "description": "erika_exskill_level_2",
      "category": "battle",
      "text": "不嫌弃的话就收下吧。",
