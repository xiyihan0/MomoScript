        "//static.kivo.wiki/images/students/%E6%B5%85%E9%BB%84%20%E7%9D%A6%E6%9C%88/%E7%A4%BC%E6%9C%8D/gallery/%E8%84%B8%E9%83%A8%E5%B7%AE%E5%88%86/CH0246_spr_07.jpg",
        "//static.kivo.wiki/images/students/%E6%B5%85%E9%BB%84%20%E7%9D%A6%E6%9C%88/%E7%A4%BC%E6%9C%8D/gallery/%E8%84%B8%E9%83%A8%E5%B7%AE%E5%88%86/CH0246_spr_10.jpg",
