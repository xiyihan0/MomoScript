      "file": "//static.kivo.wiki/voices/students/%E5%BE%A1%E7%A8%9C%20%E5%90%8D%E8%8D%89/%E6%B3%B3%E8%A3%85/jp/ch0303_cafe_monolog_4.ogg"
    },
    {
